# ==========================================
# SolarWinds Credentials
# ==========================================
SOLARWINDS_USERNAME=your_solarwinds_username
SOLARWINDS_PASSWORD=your_solarwinds_password

# ==========================================
# Qualys API Credentials
# ==========================================
QUALYS_USER=your_qualys_username
QUALYS_PASS=your_qualys_password

# ==========================================
# Qualys Target IDs
# ==========================================
# Required: The ID of the Asset Group where IPs will be replaced
QUALYS_GROUP_ID=123456

# Optional: The ID of the Authentication Record to update (Leave blank to skip)
AUTH_RECORD_ID=789012

# Optional: The ID of the Asset Tag to update (Leave blank to skip)
QUALYS_TAG_ID=345678
